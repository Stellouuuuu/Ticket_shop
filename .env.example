# Base de données (locale ou distante)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=festichill_tickets

# Pour une base distante (Railway, PlanetScale, Aiven, hébergeur…)
# DB_HOST=mysql.example.com
# DB_PORT=3306
# DB_USER=festichill_user
# DB_PASSWORD=mot_de_passe_securise
# DB_NAME=festichill_tickets
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# Admin access (used only for first bootstrap if DB has no admins)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# App URL (used in notification emails)
APP_URL=http://localhost:3000

# Email — Resend (obligatoire sur Render)
RESEND_API_KEY=
RESEND_FROM=Festichill <onboarding@resend.dev>
# Email du compte Resend (obligatoire en mode test / sans domaine vérifié)
RESEND_ACCOUNT_EMAIL=

# Fallback si aucun email dans Admin → Paramètres (sinon ignoré)
NOTIFICATION_EMAIL=

# Email — SMTP (local uniquement, bloqué sur Render)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
